{
  "name": "nitrovel",
  "description": "Nitro but with batteries",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "nitro build",
    "dev": "nitro dev",
    "preview": "nitro preview",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "prepare": "husky",
    "release:patch": "changelogen --patch --release && git push --follow-tags",
    "release:minor": "changelogen --minor --release && git push --follow-tags",
    "release:major": "changelogen --major --release && git push --follow-tags",
    "release:dry": "changelogen --dry",
    "test": "vitest --run",
    "test:verbose": "vitest run --reporter=verbose",
    "test:tree": "vitest run --reporter=tree",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "changelogen": "^0.6.2",
    "drizzle-kit": "1.0.0-beta.22",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "nitro": "latest",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "better-result": "^2.9.2",
    "consola": "^3.4.2",
    "drizzle-orm": "1.0.0-beta.22",
    "drizzle-query-logger": "^1.1.2",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "pg-native": "^3.7.0",
    "unstorage": "^1.17.5",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{js,ts,html,yaml,json,md}": "oxfmt",
    "*.{js,ts}": "oxlint"
  },
  "packageManager": "pnpm@11.1.1"
}
