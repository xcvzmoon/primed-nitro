{
  "name": "primed-nitro",
  "description": "Nitro but with batteries",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "nitro build",
    "dev": "nitro dev",
    "preview": "nitro preview",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "prepare": "husky",
    "release:patch": "changelogen --patch --release && git push --follow-tags",
    "release:minor": "changelogen --minor --release && git push --follow-tags",
    "release:major": "changelogen --major --release && git push --follow-tags",
    "release:dry": "changelogen --dry",
    "test": "vitest --run",
    "test:verbose": "vitest run --reporter=verbose",
    "test:tree": "vitest run --reporter=tree"
  },
  "devDependencies": {
    "changelogen": "^0.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "nitro": "latest",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,ts,html,yaml,json,md}": "oxfmt",
    "*.{js,ts}": "oxlint"
  },
  "packageManager": "pnpm@11.0.9"
}
